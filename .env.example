# PostgreSQL password (used by both db and app services)
POSTGRES_PASSWORD=changeme

# Docker image — set to pull pre-built image from ghcr.io instead of building locally
# TD_IMAGE=ghcr.io/mvaldes14/task-manager:latest

# App auth
TD_USERNAME=admin
TD_PASSWORD=changeme
TD_API_KEY=a-long-random-string-for-scripts

# Google Calendar (optional)
# 1. Create a Google Cloud project
# 2. Enable the Google Calendar API
# 3. Create a Service Account and download the JSON key
# 4. Share your calendar with the service account email
# 5. Paste the entire JSON key as a single line below:
GCAL_CREDENTIALS_JSON=
# Which calendar to sync to (default: primary, or use a calendar ID like abc@group.calendar.google.com)
GCAL_CALENDAR_ID=primary

# Obsidian integration (optional)
# Set this to your vault name so ![[Note]] in the FAB auto-generates obsidian:// links
OBSIDIAN_VAULT=my-vault
OBSIDIAN_INBOX=00-Inbox
